{
  "name": "grunglebird",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "deploy": "astro build && wrangler deploy",
    "check": "astro check",
    "lint:styles": "stylelint \"src/**/*.{astro,css}\" --allow-empty-input && node scripts/lint-inline-colors.mjs",
    "generate-types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply grunglebird-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply grunglebird-db --remote",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@simplewebauthn/server": "^13.3.1",
    "astro": "^6.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.12.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.104.0"
  }
}
