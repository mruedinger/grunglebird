---
import "../styles/global.css";
import { env } from "cloudflare:workers";
import { type AuthEnv, getSession } from "../lib/auth";

interface Props {
  title?: string;
  description?: string;
  /** Token-set override, e.g. "beach". Omit for the default Campari theme. */
  theme?: string;
  /** Highlights the matching nav link: "cocktails" | "tools" | "events". */
  active?: "cocktails" | "tools" | "events";
}

const {
  title = "grunglebird",
  description = "Mike's corner of the web for cocktail craft.",
  theme,
  active,
} = Astro.props;

// Cookie-only HMAC check (no DB hit). Gates the admin affordance; /admin itself
// stays reachable by URL regardless, as the permanent sign-in escape hatch.
const isAdmin = await getSession(Astro.request, env as AuthEnv);
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,500;9..144,0,600;9..144,1,500&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="shell-bar">
        <a class="brand" href="/" aria-label="grunglebird — home">
          <svg viewBox="0 0 384.66 407.07" aria-hidden="true">
            <g transform="matrix(-1,0,0,1,383.0639,-15.658)">
              <path d="m 54.312693,351.86134 c 73.126537,-2.72289 129.678857,-2.0877 197.938247,-5.4008 16.11082,-11.54425 6.27674,-37.67913 11.93039,-54.41938 3.30996,-37.01651 2.6634,-62.66217 -18.23999,-94.62755 -18.76005,-10.64016 -20.16677,-43.9204 -44.20142,-46.74605 -32.00141,-14.152 -36.18603,-30.31129 -34.65995,-53.433135 C 163.37259,76.944461 142.56058,74.292407 124.85121,73.373733 73.716225,76.905656 53.510834,95.464418 31.537459,108.97926 15.079157,110.43169 54.566336,77.290387 60.897173,76.272857 81.151571,65.266949 104.4655,62.631112 125.82287,54.544225 c 13.09661,-14.640869 39.17188,-22.294409 53.77448,-5.657367 19.04139,12.409226 7.97481,59.575002 23.25909,53.714462 15.48226,-8.958785 23.34802,-29.209757 44.3119,-30.261999 15.73361,-7.659083 32.41969,-2.103982 46.95593,5.196086 15.56751,5.964392 30.32429,16.192151 36.63443,32.230513 16.72424,28.91717 29.23546,60.84756 30.88205,94.51591 1.75663,12.9924 1.41942,26.56402 6.01575,38.9073 -0.37431,20.16588 -26.90746,11.43066 -29.06713,-3.68243 -10.54169,-4.96122 -8.28436,12.90104 -19.95514,13.9731 -8.4311,17.41999 -10.03445,33.27201 -15.07534,51.96005 -2.19986,13.86283 -12.20143,36.65898 9.1955,37.7891 26.73846,2.87174 27.47276,1.64679 45.66617,6.10745 8.88412,4.81396 7.80928,13.61277 -17.13933,25.6492 -31.72831,9.49512 -111.39573,2.61463 -136.97769,0.41898 -17.14143,-5.85268 47.14147,-15.81251 -12.37821,-15.24564 -47.40795,0.36074 -122.622455,0.83587 -142.849022,-1.53015 0,0 -5.480029,-6.39794 5.236385,-6.76745 z M 282.17588,339.55595 c 15.84942,-21.00005 11.65344,-54.51573 20.4413,-78.45723 5.92009,-20.16114 -4.18198,-29.95992 -17.69549,-42.13716 -5.82849,-8.37529 -9.02919,-1.49449 -10.66829,4.45345 1.41428,10.85418 10.85689,5.50033 2.10145,58.59464 -3.0825,20.05306 -6.79882,41.02674 -6.1207,61.34742 4.29882,2.01219 8.94406,-0.87014 11.94173,-3.80112 z"/>
            </g>
          </svg>
        </a>
        <nav class="nav">
          <a href="/cocktails" class={active === "cocktails" ? "active" : undefined}>Cocktails</a>
          <a href="/tools" class={active === "tools" ? "active" : undefined}>Tools</a>
          <a href="/events" class={active === "events" ? "active" : undefined}>Events</a>
          {isAdmin && <a class="admin-dot" href="/admin" aria-label="Admin" title="Signed in"></a>}
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <p class="footer-note">A grungle bird is not a real bird.</p>
    </footer>
  </body>
</html>
