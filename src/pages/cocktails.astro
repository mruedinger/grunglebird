---
import Layout from "../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import { type AuthEnv, getSession } from "../lib/auth";
import { UNITS } from "../lib/ingredients";
import { RECIPE_TYPES, formatAmount, normalizeSearch } from "../lib/recipes";

const isAdmin = await getSession(Astro.request, env as AuthEnv);

type IngredientRow = {
  id: number;
  name: string;
  category: string | null;
  default_unit: string | null;
  purchase_amount: number | null;
  purchase_unit: string | null;
  purchase_price_cents: number | null;
};

type RecipeRow = {
  id: number;
  name: string;
  micro: string | null;
  type: string;
  character: string | null;
  method: string;
  notes: string | null;
};

type LineRow = {
  recipe_id: number;
  ingredient_id: number;
  amount: number | null;
  unit: string;
  is_garnish: number;
  ingredient: string;
};

const [{ results: ingredients }, { results: recipes }, { results: lines }] = await Promise.all([
  env.DB.prepare(
    `SELECT id, name, category, default_unit, purchase_amount, purchase_unit, purchase_price_cents
     FROM ingredients
     ORDER BY name COLLATE NOCASE`,
  ).all<IngredientRow>(),
  env.DB.prepare(
    `SELECT id, name, micro, type, character, method, notes
     FROM recipes ORDER BY name COLLATE NOCASE`,
  ).all<RecipeRow>(),
  env.DB.prepare(
    `SELECT l.recipe_id, l.ingredient_id, l.amount, l.unit, l.is_garnish, i.name AS ingredient
     FROM recipe_lines l JOIN ingredients i ON i.id = l.ingredient_id
     ORDER BY l.recipe_id, l.is_garnish, l.position`,
  ).all<LineRow>(),
]);

const categories = [
  ...new Set(ingredients.map((i) => i.category).filter((c): c is string => !!c)),
].sort((a, b) => a.localeCompare(b));

// Recipe view model: display strings precomputed here so the client renderer stays dumb.
// "each" hides its unit (5 grapes); a no-qty line leads with its unit (twist lemon).
const lineView = (l: LineRow) => ({
  ingredient_id: l.ingredient_id,
  ingredient: l.ingredient,
  amount: l.amount,
  unit: l.unit,
  amt: [l.amount == null ? "" : formatAmount(l.amount), l.unit === "each" ? "" : l.unit]
    .filter(Boolean)
    .join(" "),
});

const recipeData = recipes.map((r) => {
  const mine = lines.filter((l) => l.recipe_id === r.id);
  return {
    id: r.id,
    name: r.name,
    micro: r.micro,
    type: r.type,
    character: r.character,
    method: r.method.split("\n"),
    notes: r.notes,
    build: mine.filter((l) => !l.is_garnish).map(lineView),
    garnish: mine.filter((l) => l.is_garnish).map(lineView),
  };
});

// Search blob per recipe: every seeded field, accent/case-folded (forward compatible —
// anything added to the view model's text fields lands here too).
const searchBlob = (r: (typeof recipeData)[number]) =>
  normalizeSearch(
    [
      r.name,
      r.micro ?? "",
      r.type,
      r.character ?? "",
      ...r.build.map((l) => l.ingredient),
      ...r.garnish.map((l) => l.ingredient),
      ...r.method,
      r.notes ?? "",
    ].join("\n"),
  );

const characters = [
  ...new Set(recipes.map((r) => r.character).filter((c): c is string => !!c)),
].sort((a, b) => a.localeCompare(b));

// Guard the inline JSON island against a literal "</script>" in recipe text.
const recipeJson = JSON.stringify(recipeData).replace(/</g, "\\u003c");

const recipesEmptyText = isAdmin ? "no recipes yet — write down the first one." : "the book's blank.";
const invEmptyText = isAdmin ? "nothing here yet — add the first bottle." : "the shelf's bare.";

// Cheat-sheet content, curated in issue #69. The conversions are deliberately
// imprecise head-math values — don't correct them.
const CONVERSIONS = [
  ["1 barspoon", "1/8 oz"],
  ["5 dashes", "1/8 oz"],
  ["30 ml", "1 oz"],
  ["750 ml", "25 oz"],
  ["1 gal", "128 oz"],
];

// Sorted alphabetically by spirit.
const BOTTLES = [
  ["aged Jamaican rum", "Appleton 12 Year, Denizen Merchant's Reserve, Planteray Xaymaca"],
  ["aged Spanish rum", "Flor de Caña 7"],
  ["bourbon", "Old Grand Dad Bonded, Old Forester 100"],
  ["coffee liqueur", "Mr Black"],
  ["dark rum", "Coruba Dark, Planteray Original Dark"],
  ["demerara rum", "Pusser's, El Dorado 5 Year"],
  ["dry curaçao", "Pierre Ferrand"],
  ["gin", "Ford's, Beefeater, Gordon's"],
  ["Irish cream", "Saint Brendan's"],
  ["Irish whiskey", "Powers Gold Label"],
  ["light rum", "Don Q, Planteray 3 Stars"],
  ["rye", "Old Forester Rye"],
  ["tequila", "Olmeca Altos"],
  ["vermouth", "Dolin"],
];
---

<Layout title="Cocktails — grunglebird" active="cocktails">
  <main class="container">
    <h1 class="hero">Cocktails</h1>

    <section class="catalog">
      <h2>Recipes</h2>
      <p class="copy muted">every drink we'd admit to</p>

      <div class="controls">
        <div class="search-ic control-grow">
          <span class="mag">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
          </span>
          <input type="search" id="recipe-filter" placeholder="Search the book" aria-label="Search recipes" autocomplete="off" />
        </div>
        {isAdmin && (
          <button type="button" class="button add-btn" id="recipe-add">Add more</button>
        )}
      </div>

      <div class="table-frame catalog-scroll">
        <table class="table">
          <thead>
            <tr>
              <th scope="col" aria-sort="ascending">
                <button type="button" class="th-sort" data-key="name">Name</button>
              </th>
              <th scope="col" aria-sort="none">
                <button type="button" class="th-sort" data-key="character">Character</button>
              </th>
            </tr>
          </thead>
          <tbody id="recipe-tbody">
            {recipeData.map((r) => (
              <tr
                class="recipe-row row-click"
                tabindex="0"
                data-id={r.id}
                data-name={r.name}
                data-character={r.character ?? ""}
                data-search={searchBlob(r)}
              >
                <td>{r.name}</td>
                <td>{r.character ?? "—"}</td>
              </tr>
            ))}
            <tr id="recipe-empty" hidden={recipeData.length > 0}>
              <td colspan="2" class="muted" id="recipe-empty-msg">{recipesEmptyText}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="catalog">
      <p class="eyebrow">Cheat Sheets</p>
      <div class="cheat-grid">
        <div class="table-frame">
          <table class="table">
            <thead>
              <tr>
                <th scope="col">not oz</th>
                <th scope="col">oz</th>
              </tr>
            </thead>
            <tbody>
              {CONVERSIONS.map(([from, to]) => (
                <tr>
                  <td>{from}</td>
                  <td>{to}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="table-frame catalog-scroll">
          <table class="table">
            <thead>
              <tr>
                <th scope="col">Spirit</th>
                <th scope="col">Mike likes</th>
              </tr>
            </thead>
            <tbody>
              {BOTTLES.map(([generic, bottles]) => (
                <tr>
                  <td>{generic}</td>
                  <td>{bottles}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="catalog">
      <h2>Inventory</h2>
      <p class="copy muted">everything behind the bar — allegedly in stock</p>

      <div class="controls">
        <div class="search-ic control-grow">
          <span class="mag">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
          </span>
          <input type="search" id="filter-name" placeholder="Filter by name or category" aria-label="Filter by name or category" autocomplete="off" />
        </div>
        {isAdmin && (
          <button type="button" class="button add-btn" id="ing-add">Add more</button>
        )}
      </div>

      <div class="table-frame catalog-scroll">
        <table class="table">
          <thead>
            <tr>
              <th scope="col" aria-sort="none">
                <button type="button" class="th-sort" data-key="name">Name</button>
              </th>
              <th scope="col" aria-sort="ascending">
                <button type="button" class="th-sort" data-key="category">Category</button>
              </th>
            </tr>
          </thead>
          <tbody id="ing-tbody">
            {ingredients.map((r) => (
              <tr
                class:list={["ing-row", isAdmin && "row-click"]}
                tabindex={isAdmin ? 0 : null}
                data-id={r.id}
                data-name={r.name}
                data-category={r.category ?? ""}
                data-unit={r.default_unit ?? ""}
                data-amount={r.purchase_amount ?? ""}
                data-punit={r.purchase_unit ?? ""}
                data-price={r.purchase_price_cents == null ? "" : String(r.purchase_price_cents / 100)}
              >
                <td>{r.name}</td>
                <td>{r.category}</td>
              </tr>
            ))}
            <tr id="ing-empty" hidden={ingredients.length > 0}>
              <td colspan="2" class="muted" id="ing-empty-msg">{invEmptyText}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <script type="application/json" id="recipe-data" set:html={recipeJson} />

    <!-- Recipe modal: view for everyone; admins can flip it in place to the build form. -->
    <div class="modal-scrim is-hidden" id="recipe-modal" role="dialog" aria-modal="true" aria-labelledby="r-title">
      <div class="modal recipe-modal">
        <div class="modal-head r-head">
          <h2 class="modal-title r-name" id="r-title">Recipe</h2>
          <button type="button" class="modal-close r-x" id="r-close" aria-label="Close">✕</button>
        </div>

        <div id="r-view">
          <p class="r-micro muted" id="r-micro"></p>
          <ul class="r-lines" id="r-build"></ul>
          <div class="r-method" id="r-method"></div>
          <p class="r-notes muted" id="r-notes"></p>
          {isAdmin && (
            <div class="modal-actions">
              <button type="button" class="button ghost sm" id="r-edit">Edit</button>
            </div>
          )}
        </div>

        {isAdmin && (
          <form id="r-form" class="is-hidden">
            <div class="alert alert-danger is-hidden" id="r-error" role="alert">
              <span class="alert-icon">!</span>
              <div><p class="alert-body" id="r-error-msg"></p></div>
            </div>
            <div class="field">
              <label for="r-name">Name</label>
              <input type="text" id="r-name" required maxlength="80" autocomplete="off" />
            </div>
            <div class="field">
              <label for="r-micro-in">Microcopy</label>
              <input type="text" id="r-micro-in" maxlength="120" autocomplete="off" />
            </div>
            <div class="pair">
              <div class="field">
                <label for="r-type">Type</label>
                <div class="select-wrap">
                  <select id="r-type" required>
                    {RECIPE_TYPES.map((t) => <option value={t}>{t}</option>)}
                  </select>
                </div>
              </div>
              <div class="field">
                <label for="r-character">Character</label>
                <div class="select-wrap">
                  <select id="r-character">
                    {characters.map((c) => <option value={c}>{c}</option>)}
                    <option value="__new__">new character…</option>
                  </select>
                </div>
                <input type="text" id="r-character-new" class="is-hidden char-new" maxlength="40" placeholder="e.g. mezcal" autocomplete="off" aria-label="New character" />
              </div>
            </div>

            <p class="label">Ingredients</p>
            <div class="line-box" id="r-build-lines"></div>
            <button type="button" class="button ghost sm add-line" data-target="r-build-lines">+ add</button>

            <p class="label">Garnish <span class="muted">(optional)</span></p>
            <div class="line-box" id="r-garnish-lines"></div>
            <button type="button" class="button ghost sm add-line" data-target="r-garnish-lines">+ add</button>

            <div class="field method-field">
              <label for="r-method-in">Method</label>
              <textarea id="r-method-in" rows="4" required placeholder="Shake with ice. Strain. Serve up."></textarea>
            </div>
            <div class="field">
              <label for="r-notes-in">Notes</label>
              <textarea id="r-notes-in" rows="2"></textarea>
            </div>

            <div class="modal-actions">
              <button type="button" class="button danger del-action is-hidden" id="r-delete">Delete</button>
              <button type="button" class="button ghost" id="r-cancel">Cancel</button>
              <button type="submit" class="button" id="r-save">Save</button>
            </div>
          </form>
        )}
      </div>
    </div>

    {isAdmin && (
      <template id="line-template">
        <div class="line-row">
          <span class="l-drag" title="Drag to reorder" aria-hidden="true">⠿</span>
          <input type="number" class="l-amount" min="0" step="any" inputmode="decimal" aria-label="Amount" placeholder="qty" />
          <div class="select-wrap l-unit-wrap">
            <select class="l-unit" aria-label="Unit">
              {UNITS.map((u) => <option value={u}>{u}</option>)}
            </select>
          </div>
          <div class="l-ing-box">
            <input type="text" class="l-ing" placeholder="ingredient" autocomplete="off" aria-label="Ingredient" />
            <ul class="l-ing-results is-hidden"></ul>
          </div>
          <button type="button" class="button ghost sm l-remove" aria-label="Remove line">✕</button>
        </div>
      </template>
    )}
    {isAdmin && (
      <script
        type="application/json"
        id="ing-data"
        set:html={JSON.stringify(
          ingredients.map((i) => ({
            id: i.id,
            name: i.name,
            category: i.category,
            default_unit: i.default_unit,
          })),
        ).replace(/</g, "\\u003c")}
      />
    )}

    {isAdmin && (
      <div class="modal-scrim is-hidden" id="ing-modal" role="dialog" aria-modal="true" aria-labelledby="ing-modal-title">
        <div class="modal">
          <div class="modal-head">
            <h2 class="modal-title" id="ing-modal-title">Add ingredient</h2>
            <button type="button" class="modal-close" id="ing-modal-close" aria-label="Close">✕</button>
          </div>
          <div class="alert alert-danger is-hidden" id="ing-error" role="alert">
            <span class="alert-icon">!</span>
            <div><p class="alert-body" id="ing-error-msg"></p></div>
          </div>
          <form id="ing-form">
            <input type="hidden" id="f-id" />
            <div class="field">
              <label for="f-name">Name</label>
              <input type="text" id="f-name" required maxlength="80" autocomplete="off" />
            </div>
            <div class="field">
              <label for="f-category">Category</label>
              <input type="text" id="f-category" required maxlength="40" list="cat-list" autocomplete="off" />
              <datalist id="cat-list">{categories.map((c) => <option value={c}></option>)}</datalist>
            </div>
            <div class="field">
              <label for="f-unit">Default unit</label>
              <div class="select-wrap">
                <select id="f-unit" required>
                  {UNITS.map((u) => <option value={u}>{u}</option>)}
                </select>
              </div>
            </div>
            <p class="label price-head">Price fallback <span class="muted">(optional)</span></p>
            <div class="field">
              <label for="f-amount">Purchase amount</label>
              <input type="number" id="f-amount" min="0" step="any" inputmode="decimal" autocomplete="off" />
            </div>
            <div class="field">
              <label for="f-punit">Purchase unit</label>
              <input type="text" id="f-punit" maxlength="20" placeholder="ml, oz, each, bag…" autocomplete="off" />
            </div>
            <div class="field">
              <label for="f-price">Purchase price ($)</label>
              <input type="number" id="f-price" min="0" step="any" inputmode="decimal" autocomplete="off" />
            </div>
            <div class="modal-actions">
              <button type="button" class="button danger del-action is-hidden" id="ing-delete">Delete</button>
              <button type="button" class="button ghost" id="ing-cancel">Cancel</button>
              <button type="submit" class="button" id="ing-save">Save</button>
            </div>
          </form>
        </div>
      </div>
    )}
  </main>

  <script>
    import { NO_QTY_UNITS } from "../lib/ingredients";
    import { CHARACTER_REQUIRED_TYPES, normalizeSearch } from "../lib/recipes";

    type RecipeLine = {
      ingredient_id: number;
      ingredient: string;
      amount: number | null;
      unit: string;
      amt: string;
    };
    type Recipe = {
      id: number;
      name: string;
      micro: string | null;
      type: string;
      character: string | null;
      method: string[];
      notes: string | null;
      build: RecipeLine[];
      garnish: RecipeLine[];
    };

    const recipeList: Recipe[] = JSON.parse(
      document.getElementById("recipe-data")?.textContent ?? "[]",
    );
    const recipesById = new Map(recipeList.map((r) => [r.id, r]));

    // --- Shared table wiring: filter + header-click sort over SSR rows (both tables) ---
    function wireTable(opts: {
      tbodyId: string;
      rowClass: string;
      searchId: string;
      emptyId: string;
      emptyMsgId: string;
      defaultKey: string;
      match: (tr: HTMLTableRowElement, q: string) => boolean;
    }) {
      const tbody = document.getElementById(opts.tbodyId);
      if (!tbody) return;
      const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>(`tr.${opts.rowClass}`));
      const emptyRow = document.getElementById(opts.emptyId) as HTMLTableRowElement | null;
      const emptyMsg = document.getElementById(opts.emptyMsgId);
      const defaultEmptyText = emptyMsg?.textContent ?? "";
      const search = document.getElementById(opts.searchId) as HTMLInputElement | null;
      const headers = Array.from(
        tbody.closest("table")?.querySelectorAll<HTMLButtonElement>("button.th-sort") ?? [],
      );

      const key = (tr: HTMLTableRowElement, k: string) => normalizeSearch(tr.dataset[k] ?? "");
      let sortKey = opts.defaultKey;
      let sortDir: "asc" | "desc" = "asc";

      const apply = () => {
        const q = normalizeSearch(search?.value ?? "").trim();
        let visible = 0;
        for (const tr of rows) {
          const m = !q || opts.match(tr, q);
          tr.hidden = !m;
          if (m) visible++;
        }

        const dir = sortDir === "asc" ? 1 : -1;
        const sorted = [...rows].sort((a, b) => {
          let c = key(a, sortKey).localeCompare(key(b, sortKey)) * dir;
          if (c === 0 && sortKey !== "name") c = key(a, "name").localeCompare(key(b, "name"));
          return c;
        });
        for (const tr of sorted) tbody.appendChild(tr);

        if (emptyRow) {
          if (emptyMsg && rows.length > 0) {
            emptyMsg.textContent = visible === 0 ? "nothing matches." : defaultEmptyText;
          }
          emptyRow.hidden = !(rows.length === 0 || visible === 0);
          tbody.appendChild(emptyRow);
        }
      };

      const syncAria = () => {
        for (const btn of headers) {
          btn.closest("th")?.setAttribute(
            "aria-sort",
            btn.dataset.key === sortKey ? (sortDir === "asc" ? "ascending" : "descending") : "none",
          );
        }
      };

      for (const btn of headers) {
        btn.addEventListener("click", () => {
          const k = btn.dataset.key ?? "name";
          if (k === sortKey) sortDir = sortDir === "asc" ? "desc" : "asc";
          else {
            sortKey = k;
            sortDir = "asc";
          }
          syncAria();
          apply();
        });
      }

      search?.addEventListener("input", apply);
      syncAria();
      apply();
    }

    wireTable({
      tbodyId: "recipe-tbody",
      rowClass: "recipe-row",
      searchId: "recipe-filter",
      emptyId: "recipe-empty",
      emptyMsgId: "recipe-empty-msg",
      defaultKey: "name",
      match: (tr, q) => (tr.dataset.search ?? "").includes(q),
    });

    wireTable({
      tbodyId: "ing-tbody",
      rowClass: "ing-row",
      searchId: "filter-name",
      emptyId: "ing-empty",
      emptyMsgId: "ing-empty-msg",
      defaultKey: "category",
      match: (tr, q) =>
        normalizeSearch(tr.dataset.name ?? "").includes(q) ||
        normalizeSearch(tr.dataset.category ?? "").includes(q),
    });

    // Row activation helper: click or Enter/Space on the focusable row.
    function onRowActivate(row: HTMLTableRowElement, fn: () => void) {
      row.addEventListener("click", fn);
      row.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          fn();
        }
      });
    }

    // --- Recipe modal: view for everyone, in-place edit/create for admins ---
    const rModal = document.getElementById("recipe-modal")!;
    const rCard = rModal.querySelector(".recipe-modal")!;
    const rView = document.getElementById("r-view")!;
    const rForm = document.getElementById("r-form") as HTMLFormElement | null;
    const rTitle = document.getElementById("r-title")!;
    let current: Recipe | null = null;

    // Garnish lines render in the same grid as the build (columns stay aligned),
    // quietly de-emphasized — optional without saying so.
    const renderLines = (ul: HTMLElement, r: Recipe) => {
      ul.textContent = "";
      const append = (lines: RecipeLine[], garnish: boolean) => {
        for (const l of lines) {
          const li = document.createElement("li");
          if (garnish) li.className = "garnish";
          const amt = document.createElement("span");
          amt.className = "amt";
          amt.textContent = l.amt;
          const ing = document.createElement("span");
          ing.className = "ing";
          ing.textContent = l.ingredient;
          li.appendChild(amt);
          li.appendChild(ing);
          ul.appendChild(li);
        }
      };
      append(r.build, false);
      if (r.garnish.length > 0) {
        const sep = document.createElement("li");
        sep.className = "sep";
        sep.setAttribute("aria-hidden", "true");
        ul.appendChild(sep);
      }
      append(r.garnish, true);
    };

    const showView = (r: Recipe) => {
      current = r;
      rTitle.textContent = r.name;
      const micro = document.getElementById("r-micro")!;
      micro.textContent = r.micro ?? "";
      micro.hidden = !r.micro;
      renderLines(document.getElementById("r-build")!, r);
      const method = document.getElementById("r-method")!;
      method.textContent = "";
      for (const step of r.method) {
        const p = document.createElement("p");
        p.textContent = step;
        method.appendChild(p);
      }
      const notes = document.getElementById("r-notes")!;
      notes.textContent = r.notes ?? "";
      notes.hidden = !r.notes;
      rCard.classList.add("is-view");
      // wordy recipes get the full modal width so the prose isn't cramped
      const proseLength = r.method.join(" ").length + (r.notes ?? "").length;
      rCard.classList.toggle("is-roomy", proseLength > 150);
      rView.classList.remove("is-hidden");
      rForm?.classList.add("is-hidden");
      rModal.classList.remove("is-hidden");
    };

    const closeRecipeModal = () => {
      rModal.classList.add("is-hidden");
      current = null;
    };

    document.getElementById("r-close")?.addEventListener("click", closeRecipeModal);
    rModal.addEventListener("click", (e) => {
      if (e.target === rModal) closeRecipeModal();
    });

    document.querySelectorAll<HTMLTableRowElement>("tr.recipe-row").forEach((row) => {
      onRowActivate(row, () => {
        const r = recipesById.get(Number(row.dataset.id));
        if (r) showView(r);
      });
    });

    // --- Admin: recipe build/edit form inside the same modal ---
    if (rForm) {
      const errBox = document.getElementById("r-error")!;
      const errMsg = document.getElementById("r-error-msg")!;
      const saveBtn = document.getElementById("r-save") as HTMLButtonElement;
      const delBtn = document.getElementById("r-delete") as HTMLButtonElement;
      const template = document.getElementById("line-template") as HTMLTemplateElement;
      const buildBox = document.getElementById("r-build-lines")!;
      const garnishBox = document.getElementById("r-garnish-lines")!;
      const f = {
        name: document.getElementById("r-name") as HTMLInputElement,
        micro: document.getElementById("r-micro-in") as HTMLInputElement,
        type: document.getElementById("r-type") as unknown as HTMLSelectElement,
        character: document.getElementById("r-character") as unknown as HTMLSelectElement,
        characterNew: document.getElementById("r-character-new") as HTMLInputElement,
        method: document.getElementById("r-method-in") as HTMLTextAreaElement,
        notes: document.getElementById("r-notes-in") as HTMLTextAreaElement,
      };

      const showError = (msg: string) => {
        errMsg.textContent = msg;
        errBox.classList.remove("is-hidden");
        // the form can be taller than the modal's scroll viewport — bring the error to the reader
        errBox.scrollIntoView({ block: "nearest", behavior: "smooth" });
      };
      const clearError = () => {
        errBox.classList.add("is-hidden");
        errMsg.textContent = "";
      };

      // ingredient data for the typeahead: exact-name index for resolution + a
      // search key over name AND category, mirroring the inventory filter
      // ("rum" surfaces Planteray OFTD).
      type Ing = { id: number; name: string; category: string | null; default_unit: string | null };
      const ingredientList: Ing[] = JSON.parse(
        document.getElementById("ing-data")?.textContent ?? "[]",
      );
      const ingIndex = new Map<string, Ing>();
      const ingSearch = ingredientList.map((i) => ({
        key: normalizeSearch(`${i.name} ${i.category ?? ""}`),
        ing: i,
      }));
      for (const i of ingredientList) ingIndex.set(normalizeSearch(i.name), i);

      const syncAmountState = (row: HTMLElement) => {
        const unit = row.querySelector(".l-unit") as unknown as HTMLSelectElement;
        const amount = row.querySelector(".l-amount") as HTMLInputElement;
        const noQty = (NO_QTY_UNITS as readonly string[]).includes(unit.value);
        amount.disabled = noQty;
        if (noQty) amount.value = "";
      };

      const addLineRow = (box: HTMLElement, line?: RecipeLine) => {
        const row = (template.content.cloneNode(true) as DocumentFragment)
          .firstElementChild as HTMLElement;
        const ing = row.querySelector(".l-ing") as HTMLInputElement;
        const results = row.querySelector(".l-ing-results") as HTMLElement;
        const unit = row.querySelector(".l-unit") as unknown as HTMLSelectElement;
        const amount = row.querySelector(".l-amount") as HTMLInputElement;

        if (line) {
          ing.value = line.ingredient;
          unit.value = line.unit;
          amount.value = line.amount == null ? "" : String(line.amount);
        }
        syncAmountState(row);

        // --- ingredient typeahead: searches name + category like the inventory filter ---
        const hideResults = () => results.classList.add("is-hidden");
        const pick = (i: Ing) => {
          ing.value = i.name;
          hideResults();
          if (i.default_unit) {
            unit.value = i.default_unit;
            syncAmountState(row);
          }
        };
        const renderResults = () => {
          const q = normalizeSearch(ing.value.trim());
          results.textContent = "";
          if (!q) {
            hideResults();
            return;
          }
          const hits = ingSearch.filter((s) => s.key.includes(q)).slice(0, 8);
          if (hits.length === 0) {
            hideResults();
            return;
          }
          for (const { ing: i } of hits) {
            const li = document.createElement("li");
            const name = document.createElement("span");
            name.textContent = i.name;
            const cat = document.createElement("span");
            cat.className = "muted";
            cat.textContent = i.category ?? "";
            li.appendChild(name);
            li.appendChild(cat);
            // pointerdown beats the input's blur, on mouse and touch alike
            li.addEventListener("pointerdown", (e) => {
              e.preventDefault();
              pick(i);
            });
            results.appendChild(li);
          }
          results.classList.remove("is-hidden");
        };
        ing.addEventListener("input", renderResults);
        ing.addEventListener("focus", renderResults);
        ing.addEventListener("blur", hideResults);
        ing.addEventListener("keydown", (e) => {
          if (results.classList.contains("is-hidden")) return;
          if (e.key === "Enter") {
            e.preventDefault();
            const q = normalizeSearch(ing.value.trim());
            const first = ingSearch.find((s) => s.key.includes(q));
            if (first) pick(first.ing);
          } else if (e.key === "Escape") {
            // consume it: closing the dropdown must not close the modal
            e.preventDefault();
            e.stopPropagation();
            hideResults();
          }
        });
        unit.addEventListener("change", () => syncAmountState(row));

        // --- drag-to-reorder via pointer events (works for mouse AND touch);
        // rows stay in their own section. insertBefore, not before/after:
        // Cloudflare's HTMLRewriter Element types shadow the DOM ones here. ---
        const handle = row.querySelector(".l-drag") as HTMLElement;
        handle.addEventListener("pointerdown", (e) => {
          e.preventDefault();
          row.classList.add("dragging");
          // listen on window, not the handle: browsers drop pointer capture when the
          // captured element is moved in the DOM, which froze the drag after one swap
          const onMove = (ev: PointerEvent) => {
            const siblings = (
              Array.from(box.querySelectorAll(".line-row")) as HTMLElement[]
            ).filter((r) => r !== row);
            const next = siblings.find(
              (r) => ev.clientY < r.getBoundingClientRect().top + r.offsetHeight / 2,
            );
            if (next) {
              if (next !== row.nextElementSibling) box.insertBefore(row, next);
            } else if (box.lastElementChild !== row) {
              box.appendChild(row);
            }
          };
          const end = () => {
            row.classList.remove("dragging");
            window.removeEventListener("pointermove", onMove);
            window.removeEventListener("pointerup", end);
            window.removeEventListener("pointercancel", end);
          };
          window.addEventListener("pointermove", onMove);
          window.addEventListener("pointerup", end);
          window.addEventListener("pointercancel", end);
        });

        row.querySelector(".l-remove")?.addEventListener("click", () => row.remove());
        box.appendChild(row);
      };

      document.querySelectorAll<HTMLButtonElement>(".add-line").forEach((btn) => {
        btn.addEventListener("click", () => {
          const box = document.getElementById(btn.dataset.target ?? "");
          if (box) addLineRow(box);
        });
      });

      const syncCharacterState = () => {
        const drink = (CHARACTER_REQUIRED_TYPES as readonly string[]).includes(f.type.value);
        f.character.disabled = !drink;
        f.characterNew.classList.toggle(
          "is-hidden",
          !drink || f.character.value !== "__new__",
        );
      };
      f.type.addEventListener("change", syncCharacterState);
      f.character.addEventListener("change", syncCharacterState);

      const showForm = (r: Recipe | null) => {
        clearError();
        rForm.reset();
        buildBox.textContent = "";
        garnishBox.textContent = "";
        if (r) {
          rTitle.textContent = "Edit recipe";
          f.name.value = r.name;
          f.micro.value = r.micro ?? "";
          f.type.value = r.type;
          if (r.character) {
            const has = [...f.character.options].some((o) => o.value === r.character);
            if (!has) {
              const opt = new Option(r.character, r.character);
              f.character.add(opt, f.character.options.length - 1);
            }
            f.character.value = r.character;
          }
          f.method.value = r.method.join("\n");
          f.notes.value = r.notes ?? "";
          for (const l of r.build) addLineRow(buildBox, l);
          for (const l of r.garnish) addLineRow(garnishBox, l);
          delBtn.dataset.id = String(r.id);
          delBtn.dataset.name = r.name;
          delBtn.classList.remove("is-hidden");
        } else {
          rTitle.textContent = "Add recipe";
          addLineRow(buildBox);
          delBtn.classList.add("is-hidden");
          delete delBtn.dataset.id;
        }
        syncCharacterState();
        rCard.classList.remove("is-view");
        rView.classList.add("is-hidden");
        rForm.classList.remove("is-hidden");
        rModal.classList.remove("is-hidden");
        f.name.focus();
      };

      document.getElementById("r-edit")?.addEventListener("click", () => {
        if (current) showForm(current);
      });
      document.getElementById("recipe-add")?.addEventListener("click", () => showForm(null));
      document.getElementById("r-cancel")?.addEventListener("click", () => {
        // editing returns to the view; a fresh create just closes
        if (current) showView(current);
        else closeRecipeModal();
      });

      delBtn.addEventListener("click", async () => {
        const id = delBtn.dataset.id;
        if (!id) return;
        const name = delBtn.dataset.name || "this recipe";
        if (!confirm(`Delete "${name}"?`)) return;
        const res = await fetch(`/api/admin/recipes/${id}`, { method: "DELETE" });
        if (res.ok) location.reload();
        else alert("Delete failed.");
      });

      type CollectedLines =
        | { lines: { ingredient_id: number; amount: string; unit: string }[] }
        | { error: string };
      const collectLines = (box: HTMLElement): CollectedLines => {
        const lines = [];
        for (const row of box.querySelectorAll<HTMLElement>(".line-row")) {
          const name = (row.querySelector(".l-ing") as HTMLInputElement).value.trim();
          const hit = ingIndex.get(normalizeSearch(name));
          if (!hit) {
            return {
              error: name
                ? `"${name}" isn't in the inventory — pick an ingredient from the list.`
                : "Every line needs an ingredient from the list.",
            };
          }
          lines.push({
            ingredient_id: hit.id,
            amount: (row.querySelector(".l-amount") as HTMLInputElement).value,
            unit: (row.querySelector(".l-unit") as unknown as HTMLSelectElement).value,
          });
        }
        return { lines };
      };

      rForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        clearError();
        const build = collectLines(buildBox);
        if ("error" in build) {
          showError(build.error);
          return;
        }
        const garnish = collectLines(garnishBox);
        if ("error" in garnish) {
          showError(garnish.error);
          return;
        }
        const id = current?.id;
        const drink = (CHARACTER_REQUIRED_TYPES as readonly string[]).includes(f.type.value);
        const payload = {
          name: f.name.value,
          micro: f.micro.value,
          type: f.type.value,
          character: !drink
            ? ""
            : f.character.value === "__new__"
              ? f.characterNew.value
              : f.character.value,
          method: f.method.value,
          notes: f.notes.value,
          lines: build.lines,
          garnish_lines: garnish.lines,
        };
        saveBtn.disabled = true;
        try {
          const res = await fetch(id ? `/api/admin/recipes/${id}` : "/api/admin/recipes", {
            method: id ? "PATCH" : "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          if (res.ok) {
            location.reload();
            return;
          }
          const { error } = (await res.json().catch(() => ({ error: "Save failed." }))) as {
            error?: string;
          };
          showError(error ?? "Save failed.");
        } catch {
          showError("Network error. Try again.");
        } finally {
          saveBtn.disabled = false;
        }
      });
    }

    // --- Admin: ingredient modal (row click opens edit; Add more opens create) ---
    const modal = document.getElementById("ing-modal");
    if (modal) {
      const form = document.getElementById("ing-form") as HTMLFormElement;
      const title = document.getElementById("ing-modal-title")!;
      const errBox = document.getElementById("ing-error")!;
      const errMsg = document.getElementById("ing-error-msg")!;
      const saveBtn = document.getElementById("ing-save") as HTMLButtonElement;
      const delBtn = document.getElementById("ing-delete") as HTMLButtonElement;
      const f = {
        id: document.getElementById("f-id") as HTMLInputElement,
        name: document.getElementById("f-name") as HTMLInputElement,
        category: document.getElementById("f-category") as HTMLInputElement,
        // HTMLSelectElement trips both the `as` overlap check and the querySelector
        // generic constraint in this TS/lib version, so use the blessed unknown escape.
        unit: document.getElementById("f-unit") as unknown as HTMLSelectElement,
        amount: document.getElementById("f-amount") as HTMLInputElement,
        punit: document.getElementById("f-punit") as HTMLInputElement,
        price: document.getElementById("f-price") as HTMLInputElement,
      };

      const showError = (msg: string) => {
        errMsg.textContent = msg;
        errBox.classList.remove("is-hidden");
      };
      const clearError = () => {
        errBox.classList.add("is-hidden");
        errMsg.textContent = "";
      };
      const closeModal = () => modal.classList.add("is-hidden");

      const openModal = (data?: DOMStringMap) => {
        clearError();
        form.reset();
        if (data) {
          title.textContent = "Edit ingredient";
          f.id.value = data.id ?? "";
          f.name.value = data.name ?? "";
          f.category.value = data.category ?? "";
          f.unit.value = data.unit ?? "";
          f.amount.value = data.amount ?? "";
          f.punit.value = data.punit ?? "";
          f.price.value = data.price ?? "";
          // snapshot the row's real identity for Delete — the name field is editable.
          delBtn.dataset.id = data.id ?? "";
          delBtn.dataset.name = data.name ?? "";
          delBtn.classList.remove("is-hidden");
        } else {
          title.textContent = "Add ingredient";
          f.id.value = "";
          delBtn.classList.add("is-hidden");
        }
        modal.classList.remove("is-hidden");
        f.name.focus();
      };

      document.getElementById("ing-add")?.addEventListener("click", () => openModal());
      document.getElementById("ing-modal-close")?.addEventListener("click", closeModal);
      document.getElementById("ing-cancel")?.addEventListener("click", closeModal);
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });

      document.querySelectorAll<HTMLTableRowElement>("tr.ing-row").forEach((row) => {
        onRowActivate(row, () => openModal(row.dataset));
      });

      delBtn.addEventListener("click", async () => {
        // use the snapshot from openModal, not the live (editable) name field, so the
        // confirm text always matches the row this id actually deletes.
        const id = delBtn.dataset.id;
        if (!id) return;
        const name = delBtn.dataset.name || "this ingredient";
        if (!confirm(`Delete "${name}"?`)) return;
        const res = await fetch(`/api/admin/ingredients/${id}`, { method: "DELETE" });
        if (res.ok) {
          location.reload();
          return;
        }
        const { error } = (await res.json().catch(() => ({ error: "Delete failed." }))) as {
          error?: string;
        };
        alert(error ?? "Delete failed.");
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        clearError();
        const id = f.id.value;
        const payload = {
          name: f.name.value,
          category: f.category.value,
          default_unit: f.unit.value,
          purchase_amount: f.amount.value,
          purchase_unit: f.punit.value,
          purchase_price: f.price.value,
        };
        saveBtn.disabled = true;
        try {
          const res = await fetch(id ? `/api/admin/ingredients/${id}` : "/api/admin/ingredients", {
            method: id ? "PATCH" : "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          if (res.ok) {
            location.reload();
            return;
          }
          const { error } = (await res.json().catch(() => ({ error: "Save failed." }))) as {
            error?: string;
          };
          showError(error ?? "Save failed.");
        } catch {
          showError("Network error. Try again.");
        } finally {
          saveBtn.disabled = false;
        }
      });
    }

    // One Escape handler for whichever modal is open.
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      if (!rModal.classList.contains("is-hidden")) closeRecipeModal();
      const ingModal = document.getElementById("ing-modal");
      if (ingModal && !ingModal.classList.contains("is-hidden")) {
        ingModal.classList.add("is-hidden");
      }
    });
  </script>

  <style>
    /* Layout only — composes the shared .table / .modal / .alert / .button / .field /
       .select-wrap primitives from markup; this block never re-styles them (see
       docs/styling.md). */
    .catalog {
      margin-top: var(--space-xl);
    }
    .controls {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      margin-bottom: var(--space-lg);
    }
    .control-grow {
      flex: 1 1 12rem;
      min-width: 0;
    }
    .add-btn {
      margin-left: auto;
    }
    /* opt-in cap on the shared .table-frame: a few rows, then sticky header + body scroll */
    .catalog-scroll {
      --table-max-block: 16rem;
    }
    /* cheat-sheet tables: side by side, stacking to one column when they can't both fit;
       start-aligned so the short conversions frame doesn't stretch to its neighbor */
    .cheat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
      gap: var(--space-lg);
      align-items: start;
    }
    /* sortable header: a plain text button (not the .button primitive) inside the th */
    .th-sort {
      font: inherit;
      color: inherit;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
    }
    .th-sort:hover {
      opacity: 0.7;
    }
    th[aria-sort="ascending"] .th-sort::after {
      content: "▲";
    }
    th[aria-sort="descending"] .th-sort::after {
      content: "▼";
    }
    .row-click {
      cursor: pointer;
    }

    /* recipe modal: taller content than the shared default, so cap + scroll the instance */
    .recipe-modal {
      max-block-size: calc(100dvh - 2 * var(--space-lg));
      overflow-y: auto;
    }
    /* view mode reads at the home card's intimate width; edit/create keeps the full
       modal width for the line-editor rows. Wordy recipes (long method/notes) opt
       back out via is-roomy so the prose isn't cramped. */
    .recipe-modal.is-view:not(.is-roomy) {
      max-width: 340px; /* recipe column width — layout one-off, matches the home card */
    }
    /* view mode: centered like the home-page recipe card — name/micro centered, a
       two-column centered ingredient grid (red amounts), muted small method/notes.
       :global() wraps the elements the client script builds: Astro's scoped styles
       only tag template-rendered elements, so script-built li/span/p miss them. */
    /* title + micro center as a unit (✕ floats out of the flow); the list block
       and everything below stay on the left rail */
    .r-head {
      position: relative;
      justify-content: center;
    }
    .r-name {
      font-size: var(--text-lg);
      text-align: center;
    }
    .r-x {
      position: absolute;
      top: 0;
      right: 0;
    }
    .r-micro {
      font-style: italic;
      text-align: center;
      margin: 0;
    }
    .r-lines {
      list-style: none;
      margin: var(--space-md) 0 0;
      padding: var(--space-sm) 0;
      border-top: 1px solid var(--hair);
      display: grid;
      grid-template-columns: max-content max-content;
      justify-content: start;
      column-gap: var(--space-sm);
      row-gap: var(--space-2xs);
    }
    .r-lines :global(li) {
      display: contents;
    }
    .r-lines :global(.amt) {
      color: var(--accent);
      font-variant-numeric: tabular-nums;
      text-align: right;
    }
    .r-lines :global(.ing) {
      color: var(--text);
      text-align: left;
    }
    /* half-width hairline between build and garnish, centered over the line block —
       display:block beats the display:contents all li get above (which has no box) */
    .r-lines :global(li.sep) {
      display: block;
      grid-column: 1 / -1;
      border-top: 2px solid var(--hair);
      width: 75%;
      margin: var(--space-2xs) auto;
    }
    .r-method {
      border-top: 1px solid var(--hair);
      padding-top: var(--space-sm);
    }
    .r-method :global(p) {
      color: var(--muted);
      font-size: var(--text-sm);
      line-height: 1.5;
      margin: 0;
    }
    .r-notes {
      font-size: var(--text-sm);
      white-space: pre-line;
      margin: var(--space-sm) 0 0;
    }

    /* edit mode: a line is amount | unit | ingredient | reorder controls */
    .line-box {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      margin-bottom: var(--space-xs);
    }
    /* two related selects share a row */
    .pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }
    .add-line {
      margin-bottom: var(--space-md);
    }
    /* one line per row: handle | qty | unit | ingredient | ✕ */
    .line-row {
      display: flex;
      gap: var(--space-xs);
      align-items: center;
    }
    .line-row.dragging {
      opacity: 0.6;
    }
    .l-drag {
      flex: none;
      cursor: grab;
      color: var(--muted);
      user-select: none;
      touch-action: none; /* the handle must not scroll the page mid-drag on touch */
    }
    .line-row .l-amount {
      flex: 0 0 4.5rem;
      min-width: 0;
    }
    .line-row .l-unit-wrap {
      flex: 0 0 auto;
    }
    .line-row .l-ing-box {
      position: relative;
      flex: 1 1 6rem;
      min-width: 0;
    }
    .line-row .l-ing {
      width: 100%;
    }
    .line-row .l-remove {
      flex: none;
    }
    /* typeahead results float under their input */
    .l-ing-results {
      position: absolute;
      inset-block-start: 100%;
      inset-inline: 0;
      z-index: 10;
      margin: var(--space-2xs) 0 0;
      padding: var(--space-2xs);
      list-style: none;
      background: var(--surface);
      border: 1px solid var(--hair);
      border-radius: var(--radius-md);
      max-block-size: 14rem;
      overflow-y: auto;
    }
    /* result rows are script-built — :global(), or the scoped rules miss them */
    .l-ing-results :global(li) {
      display: flex;
      justify-content: space-between;
      gap: var(--space-sm);
      padding: var(--space-2xs) var(--space-xs);
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .l-ing-results :global(li:hover) {
      background: color-mix(in srgb, var(--text) 10%, var(--surface));
    }
    .method-field {
      margin-top: var(--space-md);
    }
    /* narrow screens: controlled wrap — ingredient search gets its own full line */
    @media (max-width: 480px) {
      .line-row {
        flex-wrap: wrap;
      }
      .line-row .l-ing-box {
        flex: 1 1 100%;
        order: 9;
      }
    }
    .char-new {
      margin-top: var(--space-xs);
    }
    /* float the modal's destructive action away from Save to avoid a mis-click */
    .del-action {
      margin-inline-end: auto;
    }
    .price-head {
      margin-top: var(--space-md);
    }
    .is-hidden {
      display: none !important;
    }
  </style>
</Layout>
