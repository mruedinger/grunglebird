---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Cocktails — grunglebird" active="cocktails">
  <main class="container">
    <h1 class="hero">Cocktails</h1>
    <p class="copy muted">everyone keeps asking for a table…</p>

    <div class="section-head">
      <h2>Recipes</h2>
      <span class="badge">Coming soon</span>
    </div>
  </main>

  <style>
    .section-head {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      margin-top: var(--space-xl);
    }
    .section-head h2 {
      margin: 0;
    }
  </style>
</Layout>
