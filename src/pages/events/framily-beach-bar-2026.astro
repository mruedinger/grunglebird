      text-align: left;
    }
    .menu-card li {
      margin-bottom: 0.85rem;
      overflow-wrap: anywhere;
    }
    .menu-card li:last-child { margin-bottom: 0; }
    .menu-card li strong {
      display: block;
      font-family: var(--poster-font-name);
