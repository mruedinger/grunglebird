---
import Layout from "../../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import { type AuthEnv, getSession } from "../../lib/auth";
import { nameKey } from "../../lib/service-log";

// Drink names mirror the recipe DB; ingredient lists mirror it too (garnishes
// omitted) but are shortened for display: "juice"/"syrup"/"bitters" dropped,
// brand rums genericized (Planteray OFTD → dark rum, Smith & Cross → Jamaican
// rum). Old Fashioned and the Mocktails aren't in the DB yet; those are hand-kept.
const menu = [
  {
    title: 'Favorites',
    drinks: [
      { name: 'Espresso Martini', ingredients: ['demerara', 'dark rum', 'coffee liqueur', 'espresso'] },
      { name: 'Margarita', ingredients: ['lime', 'Cointreau', 'tequila blanco'] },
      { name: 'Daiquiri', ingredients: ['simple', 'lime', 'light rum'] },
    ],
  },
  {
    title: 'Tiki',
    drinks: [
      { name: 'Mai Tai', ingredients: ['demerara', 'orgeat', 'dry curaçao', 'lime', 'aged Jamaican rum'] },
      { name: 'Grungle Bird', ingredients: ['demerara', 'lime', 'grapefruit', 'Campari', 'dark rum', 'Jamaican rum'] },
      { name: "Mike's Painkiller", ingredients: ['cream of coconut', 'orange', 'pineapple', 'demerara rum'] },
      { name: 'Ancient Mariner', ingredients: ['simple', 'lime', 'grapefruit', 'allspice dram', 'aged Jamaican rum', 'demerara rum'] },
      { name: 'Pampanito', ingredients: ['demerara', 'lemon', 'allspice dram', 'dark rum', 'Angostura', 'club soda'] },
      { name: "Lauwiliwilinukunuku'oi'oi", ingredients: ['orgeat', 'lemon', 'pineapple', 'aged Jamaican rum', "Peychaud's"] },
      { name: 'Humuhumunukunukuāpuaʻa', ingredients: ['orgeat', 'lemon', 'pineapple', 'gin', "Peychaud's"] },
    ],
  },
  {
    title: 'Classics',
    drinks: [
      { name: 'Paloma', ingredients: ['lime', 'tequila blanco', 'grapefruit soda'] },
      { name: 'Ranch Water', ingredients: ['lime', 'tequila blanco', 'club soda'] },
      { name: 'Tom Collins', ingredients: ['simple', 'lemon', 'gin', 'club soda'] },
      { name: 'Old Fashioned', ingredients: ['demerara', 'bourbon', 'Angostura'] },
      { name: 'Martini', ingredients: ['gin', 'dry vermouth'] },
      { name: 'Negroni', ingredients: ['gin', 'sweet vermouth', 'Campari'] },
    ],
  },
  {
    title: 'Mocktails',
    drinks: [
      { name: 'Ginger and Juice', ingredients: ['pineapple', 'lime', 'demerara', 'spicy ginger beer'] },
      { name: 'The Hedge', ingredients: ['strawberry lemon shrub', 'soda water', 'bitters', 'mint'] },
      { name: 'House Salad', ingredients: ['cucumber', 'mint', 'lime', 'simple', 'tonic'] },
    ],
  },
];

const venmoUrl = 'https://venmo.com/u/mruedinger';

// ─── Service log (#72): admin-only, SSR-gated. Signed-out visitors get the
// poster exactly as before — none of this data or markup leaves the server. ───
const isAdmin = await getSession(Astro.request, env as AuthEnv);
const EVENT_SLUG = 'framily-beach-bar-2026';

type ServiceNightVM = {
  id: number;
  service_date: string;
  opened_at: string | null;
  closed_at: string | null;
  notes: string | null;
  guests: string[];
  drinks: { name: string; count: number }[];
  attributions: { guest: string; drink: string }[];
};

const menuDrinkNames = menu.flatMap((g) => g.drinks.map((d) => d.name));

let nights: ServiceNightVM[] = [];
let knownGuests: string[] = [];
let offMenuDrinks: string[] = [];

if (isAdmin) {
  type NightRow = {
    id: number;
    service_date: string;
    opened_at: string | null;
    closed_at: string | null;
    notes: string | null;
  };
  const [nightRows, guestRows, drinkRows, attrRows, allGuests, allDrinks] = await Promise.all([
    env.DB.prepare(
      `SELECT id, service_date, opened_at, closed_at, notes
       FROM service_nights WHERE event_slug = ?
       ORDER BY service_date DESC, id DESC`,
    ).bind(EVENT_SLUG).all<NightRow>(),
    env.DB.prepare(
      `SELECT ng.night_id, g.name
       FROM service_night_guests ng
       JOIN service_guests g ON g.id = ng.guest_id
       JOIN service_nights n ON n.id = ng.night_id
       WHERE n.event_slug = ?
       ORDER BY g.name COLLATE NOCASE`,
    ).bind(EVENT_SLUG).all<{ night_id: number; name: string }>(),
    env.DB.prepare(
      `SELECT nd.night_id, d.name, nd.count
       FROM service_night_drinks nd
       JOIN service_drinks d ON d.id = nd.drink_id
       JOIN service_nights n ON n.id = nd.night_id
       WHERE n.event_slug = ?
       ORDER BY nd.count DESC, d.name COLLATE NOCASE`,
    ).bind(EVENT_SLUG).all<{ night_id: number; name: string; count: number }>(),
    env.DB.prepare(
      `SELECT ngd.night_id, g.name AS guest, d.name AS drink
       FROM service_night_guest_drinks ngd
       JOIN service_guests g ON g.id = ngd.guest_id
       JOIN service_drinks d ON d.id = ngd.drink_id
       JOIN service_nights n ON n.id = ngd.night_id
       WHERE n.event_slug = ?
       ORDER BY g.name COLLATE NOCASE`,
    ).bind(EVENT_SLUG).all<{ night_id: number; guest: string; drink: string }>(),
    env.DB.prepare(`SELECT name FROM service_guests ORDER BY name COLLATE NOCASE`)
      .all<{ name: string }>(),
    env.DB.prepare(`SELECT name FROM service_drinks ORDER BY name COLLATE NOCASE`)
      .all<{ name: string }>(),
  ]);

  nights = nightRows.results.map((r) => ({
    ...r,
    guests: guestRows.results.filter((x) => x.night_id === r.id).map((x) => x.name),
    drinks: drinkRows.results
      .filter((x) => x.night_id === r.id)
      .map((x) => ({ name: x.name, count: x.count })),
    attributions: attrRows.results
      .filter((x) => x.night_id === r.id)
      .map((x) => ({ guest: x.guest, drink: x.drink })),
  }));
  knownGuests = allGuests.results.map((g) => g.name);
  const menuKeys = new Set(menuDrinkNames.map(nameKey));
  offMenuDrinks = allDrinks.results.map((d) => d.name).filter((n) => !menuKeys.has(nameKey(n)));
}

// ─── Public stats (#75): night-level AGGREGATES only, visible to everyone. These
// queries never join service_guests and never touch service_night_guest_drinks —
// the public view is pure aggregate, so no individual is identifiable. Drink names
// are fine; guest data is counts only. Runs for every visitor, signed in or not. ───
type StatNight = {
  date: string;
  opened_at: string | null;
  total: number;
  guests: number;
  drinks: { name: string; count: number }[];
};

const [statNightRows, statDrinkRows, statGuestRows, statUniqueRow] = await Promise.all([
  // opened_at carries the trend chart's x-position (start of service); it's bar
  // hours, not guest data, so it's fine in the public view.
  env.DB.prepare(
    `SELECT id, service_date, opened_at FROM service_nights
     WHERE event_slug = ? ORDER BY service_date ASC, id ASC`,
  ).bind(EVENT_SLUG).all<{ id: number; service_date: string; opened_at: string | null }>(),
  env.DB.prepare(
    `SELECT nd.night_id, d.name, nd.count
     FROM service_night_drinks nd
     JOIN service_drinks d ON d.id = nd.drink_id
     JOIN service_nights n ON n.id = nd.night_id
     WHERE n.event_slug = ?`,
  ).bind(EVENT_SLUG).all<{ night_id: number; name: string; count: number }>(),
  // COUNT(*) per night = distinct guests that night (UNIQUE night_id,guest_id).
  env.DB.prepare(
    `SELECT ng.night_id, COUNT(*) AS guests
     FROM service_night_guests ng
     JOIN service_nights n ON n.id = ng.night_id
     WHERE n.event_slug = ?
     GROUP BY ng.night_id`,
  ).bind(EVENT_SLUG).all<{ night_id: number; guests: number }>(),
  // Overall unique guests = distinct identities across nights, NOT a sum of the
  // nightly counts — a repeat visitor must count once.
  env.DB.prepare(
    `SELECT COUNT(DISTINCT ng.guest_id) AS guests
     FROM service_night_guests ng
     JOIN service_nights n ON n.id = ng.night_id
     WHERE n.event_slug = ?`,
  ).bind(EVENT_SLUG).first<{ guests: number }>(),
]);

// Deterministic ordering everywhere: quantity desc, then name asc.
const byCountThenName = (a: { name: string; count: number }, b: { name: string; count: number }) =>
  b.count - a.count || a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });

const guestCountByNight = new Map(statGuestRows.results.map((r) => [r.night_id, r.guests]));

const statNights: StatNight[] = statNightRows.results.map((n) => {
  const drinks = statDrinkRows.results
    .filter((d) => d.night_id === n.id)
    .map((d) => ({ name: d.name, count: d.count }))
    .sort(byCountThenName);
  return {
    date: n.service_date,
    opened_at: n.opened_at,
    total: drinks.reduce((s, d) => s + d.count, 0),
    guests: guestCountByNight.get(n.id) ?? 0,
    drinks,
  };
});

// Overall aggregates. Total reconciles with the admin per-night sums by construction.
const overallDrinks = statNights.reduce((s, n) => s + n.total, 0);
const overallGuests = statUniqueRow?.guests ?? 0;
const drinkTotals = new Map<string, number>();
for (const d of statDrinkRows.results) {
  drinkTotals.set(d.name, (drinkTotals.get(d.name) ?? 0) + d.count);
}
const topDrinks = [...drinkTotals.entries()]
  .map(([name, count]) => ({ name, count }))
  .sort(byCountThenName);
const drinkVariety = topDrinks.length;
const mostPopular = topDrinks[0] ?? null;
const TOP_N = 8;
const topDrinksShown = topDrinks.slice(0, TOP_N);
const topDrinksMore = topDrinks.length - topDrinksShown.length;

// Chart scaling — guard divide-by-zero on a zero-drink run (points sit on the floor).
const maxNightTotal = Math.max(0, ...statNights.map((n) => n.total));
const maxDrinkTotal = topDrinksShown[0]?.count ?? 0;

// ─── Trend chart geometry: pours per night on a true *time* x-axis. Each point
// sits at the start of that service (service_date + opened_at), so the spacing
// reflects real elapsed time, not even slots. Computed server-side into percent
// coords; the markup is a CSS-positioned line + dots (SVG only draws the path). ───
function startTs(iso: string, opened: string | null): number {
  const [y, m, d] = iso.split('-').map(Number);
  const [hh, mm] = (opened ?? '00:00').split(':').map(Number);
  return new Date(y, m - 1, d, hh || 0, mm || 0).getTime();
}
// Inset the endpoints so edge dots/labels don't clip the plot.
const X_PAD = 6;
const trendRaw = statNights
  .map((n) => ({ date: n.date, total: n.total, ts: startTs(n.date, n.opened_at) }))
  .sort((a, b) => a.ts - b.ts);
const tsMin = Math.min(...trendRaw.map((p) => p.ts));
const tsMax = Math.max(...trendRaw.map((p) => p.ts));
const tsSpan = tsMax - tsMin;
const trendPoints = trendRaw.map((p) => {
  const xFrac = tsSpan > 0 ? (p.ts - tsMin) / tsSpan : 0.5;
  const x = X_PAD + xFrac * (100 - 2 * X_PAD);
  const y = maxNightTotal ? (p.total / maxNightTotal) * 100 : 0;
  return { ...p, x, y };
});
// SVG polyline runs top-down (y=0 at top), so flip the floor-anchored y.
const trendPath = trendPoints.map((p) => `${p.x},${100 - p.y}`).join(' ');

// Parts-built local date — new Date("YYYY-MM-DD") parses as UTC and can shift a day.
function dateLabel(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('en-US', {
    weekday: 'short', month: 'short', day: 'numeric', year: 'numeric',
  });
}

// Compact label for the trend chart's x-axis.
function shortDate(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Guard the inline JSON island against a literal "</script>" in night text.
const logJson = JSON.stringify({
  slug: EVENT_SLUG,
  nights,
  knownGuests,
  offMenuDrinks,
  menu: menuDrinkNames,
}).replace(/</g, '\\u003c');
---

<Layout
  theme="beach"
  title="Mike's Beach Bar"
  description="The menu at Mike's Beach Bar."
  active="events"
>
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Bungee+Shade&family=Limelight&family=Yellowtail&display=swap"
    rel="stylesheet"
  />

  <main class="container event-poster">
    <header>
      <h1>Mike's Beach Bar</h1>
      <p class="tagline">we'll try to keep the sand out of your drink</p>
    </header>

    <section>
      <h2>Donate</h2>
      <p>
        Cover the booze and <a href="https://www.nccoast.org/give/" target="_blank" rel="noopener">support the coast</a>
        <br />
        Suggested donation $3 per drink
        <br />
        Thank you <span class="heart">♥</span>
      </p>

      <div class="venmo">
        <a class="poster-btn" href={venmoUrl} target="_blank" rel="noopener">Venmo @mruedinger</a>
      </div>
    </section>

    <section>
      <h2>The Menu</h2>

      <article class="menu-card">
        {menu.map((group) => (
          <Fragment>
            <h3>{group.title}</h3>
            <ul>
              {group.drinks.map((d) => (
                <li>
                  <strong>{d.name}</strong>
                  <span class="menu-ingredients">
                    {d.ingredients.map((ing, i) => (
                      <Fragment>{i > 0 && ' · '}<span class="ing">{ing}</span></Fragment>
                    ))}
                  </span>
                </li>
              ))}
            </ul>
          </Fragment>
        ))}
      </article>

      <p class="poster-muted">(and more!)</p>
    </section>

    <section class="stats">
      <h2>Stats</h2>
      <p class="poster-muted stats-intro">Tallied off the legal pad. Margin of error: the legal pad.</p>

      {statNights.length === 0 ? (
        <p class="poster-muted stats-empty">Bar's not open yet. Nothing to count.</p>
      ) : (
        <Fragment>
          <div class="stat-callouts">
            <div class="stat-callout">
              <span class="stat-num">{overallDrinks}</span>
              <span class="stat-cap">drinks poured</span>
            </div>
            <div class="stat-callout">
              <span class="stat-num">{overallGuests}</span>
              <span class="stat-cap">guests served</span>
            </div>
            <div class="stat-callout">
              <span class="stat-num stat-num-text">{mostPopular ? mostPopular.name : '—'}</span>
              <span class="stat-cap">house favorite</span>
            </div>
            <div class="stat-callout">
              <span class="stat-num">{drinkVariety}</span>
              <span class="stat-cap">drinks in rotation</span>
            </div>
          </div>

          <figure class="chart chart-nights">
            <figcaption>Pours per night</figcaption>
            <div class="line-plot">
              {trendPoints.length > 1 && (
                <svg class="line-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                  <polyline class="line-path" points={trendPath} vector-effect="non-scaling-stroke" />
                </svg>
              )}
              {trendPoints.map((p) => (
                <div
                  class="line-point"
                  style={`left:${p.x}%;bottom:${p.y}%`}
                  title={`${dateLabel(p.date)} — ${p.total} ${p.total === 1 ? 'drink' : 'drinks'}`}
                >
                  <span class="line-val">{p.total}</span>
                  <span class="line-dot"></span>
                </div>
              ))}
            </div>
            <div class="line-axis">
              {trendPoints.map((p) => (
                <span class="line-tick" style={`left:${p.x}%`}>{shortDate(p.date)}</span>
              ))}
            </div>
          </figure>

          <figure class="chart chart-top">
            <figcaption>Top of the rail</figcaption>
            {mostPopular ? (
              <Fragment>
                <ol class="bars-h">
                  {topDrinksShown.map((d) => (
                    <li class="bar-h-row">
                      <span class="bar-h-name">{d.name}</span>
                      <span class="bar-h-track">
                        <span
                          class="bar-h-fill"
                          style={`--w:${maxDrinkTotal ? Math.round((d.count / maxDrinkTotal) * 100) : 0}%`}
                        ></span>
                      </span>
                      <span class="bar-h-val">{d.count}</span>
                    </li>
                  ))}
                </ol>
                {topDrinksMore > 0 && (
                  <details class="bars-h-more">
                    <summary class="poster-muted">+{topDrinksMore} more on the board</summary>
                    <ol class="bars-h bars-h-rest">
                      {topDrinks.slice(TOP_N).map((d) => (
                        <li class="bar-h-row">
                          <span class="bar-h-name">{d.name}</span>
                          <span class="bar-h-track">
                            <span
                              class="bar-h-fill"
                              style={`--w:${maxDrinkTotal ? Math.round((d.count / maxDrinkTotal) * 100) : 0}%`}
                            ></span>
                          </span>
                          <span class="bar-h-val">{d.count}</span>
                        </li>
                      ))}
                    </ol>
                  </details>
                )}
              </Fragment>
            ) : (
              <p class="poster-muted">no pours logged yet</p>
            )}
          </figure>

          <div class="stat-nights">
            <p class="stat-nights-hint poster-muted">Each night's tab. Tap to unfold.</p>
            {statNights.map((n) => (
              <details class="stat-night">
                <summary>
                  <span class="sn-date">{dateLabel(n.date)}</span>
                  <span class="sn-meta poster-muted">
                    {[
                      `${n.total} ${n.total === 1 ? 'drink' : 'drinks'}`,
                      n.guests > 0 && `${n.guests} ${n.guests === 1 ? 'guest' : 'guests'}`,
                      n.drinks[0] && `top: ${n.drinks[0].name}`,
                    ]
                      .filter(Boolean)
                      .join(' · ')}
                  </span>
                </summary>
                <div class="sn-body">
                  {n.drinks.length > 0 ? (
                    <ul class="sn-tally">
                      {n.drinks.map((d) => (
                        <li><span class="sn-count">{d.count}</span> {d.name}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="poster-muted">no pours logged this night</p>
                  )}
                </div>
              </details>
            ))}
          </div>
        </Fragment>
      )}
    </section>
  </main>

  {isAdmin && (
    <section class="container service-log" id="service-log">
      <p class="eyebrow">After hours</p>
      <h2>Service log</h2>
      <p class="muted">What the legal pad saw.</p>

      <button type="button" class="button" id="log-open">Log a night</button>

      <form id="log-form" class="card is-hidden">
        <h3 id="lf-title">New night</h3>

        <div class="alert alert-danger is-hidden" id="lf-error" role="alert">
          <span class="alert-icon">!</span>
          <div><p class="alert-body" id="lf-error-msg"></p></div>
        </div>

        <div class="lf-when">
          <div class="field lf-date-field">
            <label for="lf-date">Date</label>
            <input type="date" id="lf-date" required />
          </div>
          <div class="field">
            <label for="lf-open">Opened</label>
            <input type="time" id="lf-open" />
          </div>
          <div class="field">
            <label for="lf-close">Closed</label>
            <input type="time" id="lf-close" />
          </div>
        </div>

        <p class="label">Guests</p>
        <div class="lf-chips" id="lf-guest-chips"></div>
        <div class="lf-addrow">
          <input
            type="text"
            id="lf-guest-in"
            list="lf-guest-list"
            placeholder="who showed up"
            maxlength="60"
            autocomplete="off"
          />
          <datalist id="lf-guest-list">
            {knownGuests.map((g) => <option value={g}></option>)}
          </datalist>
          <button type="button" class="button ghost sm" id="lf-guest-add">+ add</button>
        </div>

        <p class="label">Drinks</p>
        <div class="lf-tally" id="lf-tally"></div>
        <div class="lf-addrow">
          <input
            type="text"
            id="lf-drink-in"
            list="lf-drink-list"
            placeholder="off-menu drink"
            maxlength="80"
            autocomplete="off"
          />
          <datalist id="lf-drink-list">
            {offMenuDrinks.map((d) => <option value={d}></option>)}
          </datalist>
          <button type="button" class="button ghost sm" id="lf-drink-add">+ add</button>
        </div>

        <details class="lf-attr" id="lf-attr">
          <summary>Favorites <span class="muted">(optional)</span></summary>
          <p class="help">What each guest favored — not a record of everything they drank.</p>
          <div class="lf-attr-body" id="lf-attr-body"></div>
        </details>

        <div class="field">
          <label for="lf-notes">Notes</label>
          <textarea id="lf-notes" rows="3" maxlength="2000" placeholder="anything memorable"></textarea>
        </div>

        <div class="lf-actions">
          <button type="button" class="button danger is-hidden" id="lf-delete">Delete</button>
          <button type="button" class="button ghost" id="lf-cancel">Cancel</button>
          <button type="submit" class="button" id="lf-save">Save</button>
        </div>
      </form>

      <template id="lf-row-tpl">
        <div class="lf-row">
          <span class="lf-row-name"></span>
          <input type="number" min="0" max="999" step="1" inputmode="numeric" placeholder="0" />
        </div>
      </template>

      <div class="log-nights" id="log-nights">
        {nights.map((n) => {
          const total = n.drinks.reduce((s, d) => s + d.count, 0);
          // Favorites read per guest ("Sara: Daiquiri"), not per drink.
          const favs = n.guests
            .map((g) => ({
              guest: g,
              drinks: n.attributions.filter((a) => a.guest === g).map((a) => a.drink),
            }))
            .filter((x) => x.drinks.length > 0);
          return (
            <details class="card log-night">
              <summary>
                <span class="ln-date">{dateLabel(n.service_date)}</span>
                <span class="muted ln-meta">
                  {[
                    n.guests.length > 0 &&
                      `${n.guests.length} ${n.guests.length === 1 ? 'guest' : 'guests'}`,
                    total > 0 && `${total} ${total === 1 ? 'drink' : 'drinks'}`,
                  ]
                    .filter(Boolean)
                    .join(' · ')}
                </span>
              </summary>
              <div class="ln-body">
                {(n.opened_at || n.closed_at) && (
                  <p class="muted ln-times">{n.opened_at ?? '?'} – {n.closed_at ?? '?'}</p>
                )}
                {n.guests.length > 0 && <p class="ln-guests">{n.guests.join(', ')}</p>}
                {n.drinks.length > 0 && (
                  <ul class="ln-tally">
                    {n.drinks.map((d) => (
                      <li>
                        <span class="ln-count">{d.count}</span> {d.name}
                      </li>
                    ))}
                  </ul>
                )}
                {favs.length > 0 && (
                  <p class="ln-favs">
                    <span class="muted">favorites — </span>
                    {favs.map((x, i) => (
                      <Fragment>{i > 0 && '; '}{x.guest}: {x.drinks.join(', ')}</Fragment>
                    ))}
                  </p>
                )}
                {n.notes && <p class="ln-notes">{n.notes}</p>}
                <div class="ln-actions">
                  <button type="button" class="button ghost sm ln-edit" data-id={n.id}>Edit</button>
                </div>
              </div>
            </details>
          );
        })}
        {nights.length === 0 && <p class="muted">Nothing on the books yet.</p>}
      </div>

      <script type="application/json" id="log-data" set:html={logJson} />
    </section>
  )}

  <style>
    /* ─── Poster island (#44) ────────────────────────────────────────────────
       This event poster is a self-contained style island. Its bespoke palette and
       every bespoke element (buttons, panels, muted text) are defined LOCALLY here
       and scoped to this page by Astro — a change to a global primitive can't reach
       in, and nothing here reaches out. The only things it shares with the rest of
       the site are the shell (nav/header/footer, outside this <main>) and the max
       content width (.container). Plain body copy *respects* the shell-retint
       tokens (--text/--font-body) the same way it respects max-width; bespoke fonts
       (Bungee Shade / Yellowtail / Limelight) are the sanctioned event-body exception. */

    /* — the poster's font set. Body text is Inter, inherited from the shell's
         --font-body; --poster-font-name is the same face as the site's display
         font (both already loaded by the shell on every page). — */
    .event-poster {
      --poster-font-hero: "Bungee Shade", Georgia, serif;
      --poster-font-script: "Yellowtail", Georgia, cursive, serif;
      --poster-font-menu: "Limelight", Georgia, serif;
      --poster-font-name: "Bricolage Grotesque", system-ui, sans-serif;
    }

    /* — local palette: literals this poster owns, independent of the shell — */
    .event-poster {
      text-align: center;
      --poster-paper: #fffcf3;
      --poster-line: #e8cea0;
      --poster-ocean: #00b4cc;
      --poster-ocean-dark: #006d7a;
      --poster-sun: #ffa726;
      --poster-sunset: #ff5252;
      --poster-ink: #43372d;
      --poster-ink-soft: #877161;
      --poster-action-ink: #ffffff; /* text on a filled button */
    }

    /* — bespoke headings + links — scoped under .event-poster so they can't
         bleed into the admin service-log section below the island */
    .event-poster h1 {
      font-family: var(--poster-font-hero);
      font-weight: 400;
      font-size: 2.75rem;
      line-height: 1.2;
      color: var(--poster-sunset);
      margin: 0 0 0.15em;
    }
    .event-poster h2 {
      font-family: var(--poster-font-script);
      font-weight: 400;
      font-size: 2.25rem;
      line-height: 1.3;
      margin: 2.5rem 0 0.5rem;
      color: var(--poster-ocean);
    }
    .event-poster a {
      color: var(--poster-ocean);
      text-decoration: none;
    }
    .event-poster a:hover {
      text-decoration: underline;
    }
    .tagline {
      margin: 0;
      font-size: 1.05rem;
      color: var(--poster-ink-soft);
    }

    /* — local button (frozen from main's beach look; no .radiate on main) — */
    .event-poster .poster-btn {
      font: inherit;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.65rem 1.2rem;
      border: none;
      border-radius: 12px;
      text-decoration: none;
      box-shadow: none;
      background: var(--poster-sunset);
      color: var(--poster-action-ink);
      transition: background 140ms ease;
    }
    .event-poster .poster-btn:hover {
      background: var(--poster-sun);
      text-decoration: none;
    }

    .menu-card {
      max-width: 36rem;
      margin: 1rem auto 0.5rem;
      background: var(--poster-paper);
      border: 1px solid var(--poster-line);
      border-radius: 12px;
      padding: 1.5rem 1rem;
    }
    .menu-card h3 {
      margin: 1.75rem 0 0.85rem;
      letter-spacing: 0.05em;
      font-size: 1.4rem;
      line-height: 1.15;
      color: var(--poster-ocean-dark);
      font-family: var(--poster-font-menu);
      font-weight: 400;
    }
    .menu-card h3:first-child { margin-top: 0; }
    .menu-card ul {
      list-style: none;
