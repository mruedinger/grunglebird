    /* Chart A — pours per night on a time axis (CSS-positioned line + dots).
       Coords are percentages computed server-side; the SVG only draws the path,
       stretched to the plot box (non-scaling stroke keeps the line crisp). */
    .line-plot {
      position: relative;
      height: 120px;
      margin: 1.5rem 0.25rem 0;
