      color: var(--poster-ink-soft);
      white-space: nowrap;
    }

    /* Chart B — top drinks by quantity (horizontal bars) */
    .bars-h {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.5rem;
      text-align: left;
    }
    .bar-h-row {
