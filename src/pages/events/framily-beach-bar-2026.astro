      width: fit-content;
    }
    .bars-h-more[open] > summary { margin-bottom: 0.5rem; }
    .bars-h-rest { margin-top: 0; }

    /* Per-night collapsed rows (native <details>, daily granularity) */
    .stat-nights {
      max-width: 36rem;
      margin: 0 auto;
      text-align: left;
    }
    .stat-nights-hint {
      text-align: center;
      font-size: 0.8rem;
      margin: 0 0 0.75rem;
