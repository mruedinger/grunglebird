  </style>

  <script>
    import { nameKey } from "../../lib/service-log";

    type NightVM = {
      id: number;
      service_date: string;
      opened_at: string | null;
      closed_at: string | null;
      notes: string | null;
      guests: string[];
      drinks: { name: string; count: number }[];
      attributions: { guest: string; drink: string }[];
    };

    // Admin-only island: absent for signed-out visitors, so this no-ops.
    const island = document.getElementById("log-data");
    if (island) initServiceLog(JSON.parse(island.textContent ?? "{}"));

    function initServiceLog(data: {
      slug: string;
      nights: NightVM[];
      knownGuests: string[];
      offMenuDrinks: string[];
      menu: string[];
    }) {
      const $ = (id: string) => document.getElementById(id)!;
      const openBtn = $("log-open") as HTMLButtonElement;
      const form = $("log-form") as HTMLFormElement;
      const title = $("lf-title");
      const errorBox = $("lf-error");
      const errorMsg = $("lf-error-msg");
      const dateIn = $("lf-date") as HTMLInputElement;
      const openIn = $("lf-open") as HTMLInputElement;
      const closeIn = $("lf-close") as HTMLInputElement;
      const notesIn = $("lf-notes") as HTMLTextAreaElement;
      const chipRow = $("lf-guest-chips");
      const guestIn = $("lf-guest-in") as HTMLInputElement;
      const drinkIn = $("lf-drink-in") as HTMLInputElement;
      const tally = $("lf-tally");
      const rowTpl = $("lf-row-tpl") as HTMLTemplateElement;
      const attrDetails = $("lf-attr") as HTMLDetailsElement;
      const attrBody = $("lf-attr-body");
      const deleteBtn = $("lf-delete") as HTMLButtonElement;

      const SEP = "\u0000";
      const menuRows = data.menu.map((name) => ({ name, key: nameKey(name) }));
      const menuKeys = new Set(menuRows.map((r) => r.key));

      let editingId: number | null = null;
      let guests: { name: string; key: string }[] = [];
      let extras: { name: string; key: string }[] = []; // off-menu rows in the tally
      let attrs = new Set<string>(); // `${guestKey}\u0000${drinkKey}`

      const showError = (msg: string) => {
        errorMsg.textContent = msg;
        errorBox.classList.remove("is-hidden");
      };

      function buildTally(counts: Map<string, number>) {
        tally.innerHTML = "";
        for (const d of [...menuRows, ...extras]) {
          const node = rowTpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
          node.dataset.key = d.key;
          node.dataset.name = d.name;
          node.querySelector(".lf-row-name")!.textContent = d.name;
          const input = node.querySelector("input")!;
          input.setAttribute("aria-label", `How many: ${d.name}`);
          const c = counts.get(d.key) ?? 0;
          if (c > 0) input.value = String(c);
          tally.appendChild(node);
        }
      }

      function readCounts(): { name: string; key: string; count: number }[] {
        return [...tally.querySelectorAll<HTMLElement>(".lf-row")].map((row) => ({
          name: row.dataset.name!,
          key: row.dataset.key!,
          count: Math.max(0, Math.floor(Number(row.querySelector("input")!.value) || 0)),
        }));
      }

      function renderChips() {
        chipRow.innerHTML = "";
        for (const g of guests) {
          const b = document.createElement("button");
          b.type = "button";
          b.className = "button ghost sm lf-chip";
          b.textContent = `${g.name} ✕`;
          b.setAttribute("aria-label", `Remove ${g.name}`);
          b.addEventListener("click", () => {
            guests = guests.filter((x) => x.key !== g.key);
            attrs = new Set([...attrs].filter((k) => !k.startsWith(g.key + SEP)));
            renderChips();
            renderAttr();
          });
          chipRow.appendChild(b);
        }
      }

      // Guests × counted drinks; a pressed chip = "this was one of the guest's
      // favorites that night" — a stated preference, not a record of consumption.
      function renderAttr() {
        if (!attrDetails.open) return;
        const counted = readCounts().filter((d) => d.count > 0);
        attrBody.innerHTML = "";
        if (guests.length === 0 || counted.length === 0) {
          const p = document.createElement("p");
          p.className = "muted";
          p.textContent = "add guests and a few drinks first.";
          attrBody.appendChild(p);
          return;
        }
        for (const g of guests) {
          const row = document.createElement("div");
          row.className = "lf-attr-row";
          const label = document.createElement("span");
          label.className = "lf-attr-name";
          label.textContent = g.name;
          row.appendChild(label);
          for (const d of counted) {
            const b = document.createElement("button");
            b.type = "button";
            const k = g.key + SEP + d.key;
            const on = attrs.has(k);
            b.className = on ? "button sm" : "button ghost sm";
            b.setAttribute("aria-pressed", String(on));
            b.textContent = d.name;
            b.addEventListener("click", () => {
              if (attrs.has(k)) attrs.delete(k);
              else attrs.add(k);
              renderAttr();
            });
            row.appendChild(b);
          }
          attrBody.appendChild(row);
        }
      }

      function addGuest() {
        const name = guestIn.value.trim();
        if (!name) return;
        const key = nameKey(name);
        if (key && !guests.some((g) => g.key === key)) {
          guests.push({ name, key });
          renderChips();
          renderAttr();
        }
        guestIn.value = "";
        guestIn.focus();
      }

      function addDrink() {
        const name = drinkIn.value.trim();
        if (!name) return;
        const key = nameKey(name);
        if (key && !menuKeys.has(key) && !extras.some((d) => d.key === key)) {
          const counts = new Map(readCounts().map((d) => [d.key, d.count]));
          extras.push({ name, key });
          counts.set(key, counts.get(key) || 1);
          buildTally(counts);
        }
        drinkIn.value = "";
        const row = tally.querySelector<HTMLElement>(`[data-key="${CSS.escape(key)}"]`);
        row?.querySelector("input")?.focus();
        renderAttr();
      }

      function localToday(): string {
        const d = new Date();
        const mm = String(d.getMonth() + 1).padStart(2, "0");
        const dd = String(d.getDate()).padStart(2, "0");
        return `${d.getFullYear()}-${mm}-${dd}`;
      }

      function openForm(night: NightVM | null) {
        editingId = night?.id ?? null;
        title.textContent = night ? "Edit night" : "New night";
        dateIn.value = night?.service_date ?? localToday();
        openIn.value = night?.opened_at ?? "";
        closeIn.value = night?.closed_at ?? "";
        notesIn.value = night?.notes ?? "";
        guests = (night?.guests ?? []).map((name) => ({ name, key: nameKey(name) }));
        extras = (night?.drinks ?? [])
          .filter((d) => !menuKeys.has(nameKey(d.name)))
          .map((d) => ({ name: d.name, key: nameKey(d.name) }));
        attrs = new Set(
          (night?.attributions ?? []).map((a) => nameKey(a.guest) + SEP + nameKey(a.drink)),
        );
        buildTally(new Map((night?.drinks ?? []).map((d) => [nameKey(d.name), d.count])));
        renderChips();
        attrDetails.open = attrs.size > 0;
        renderAttr();
        deleteBtn.classList.toggle("is-hidden", editingId === null);
        errorBox.classList.add("is-hidden");
        form.classList.remove("is-hidden");
        openBtn.classList.add("is-hidden");
        form.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function closeForm() {
        form.classList.add("is-hidden");
        openBtn.classList.remove("is-hidden");
        editingId = null;
      }

      openBtn.addEventListener("click", () => openForm(null));
      $("lf-cancel").addEventListener("click", closeForm);
      $("lf-guest-add").addEventListener("click", addGuest);
      $("lf-drink-add").addEventListener("click", addDrink);
      for (const [input, add] of [[guestIn, addGuest], [drinkIn, addDrink]] as const) {
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            add();
          }
        });
      }
      attrDetails.addEventListener("toggle", renderAttr);
      tally.addEventListener("input", renderAttr);

      document.querySelectorAll<HTMLElement>(".ln-edit").forEach((b) => {
        b.addEventListener("click", () => {
          const night = data.nights.find((n) => n.id === Number(b.dataset.id));
          if (night) openForm(night);
        });
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const guestKeys = new Set(guests.map((g) => g.key));
        const counted = readCounts().filter((d) => d.count > 0);
        const drinkNames = new Map(counted.map((d) => [d.key, d.name]));
        const guestNames = new Map(guests.map((g) => [g.key, g.name]));
        const payload = {
          event_slug: data.slug,
          service_date: dateIn.value,
          opened_at: openIn.value || null,
          closed_at: closeIn.value || null,
          notes: notesIn.value.trim() || null,
          guests: guests.map((g) => g.name),
          drinks: counted.map((d) => ({ name: d.name, count: d.count })),
          // Drop attributions whose guest was removed or whose drink fell to 0.
          attributions: [...attrs]
            .map((k) => k.split(SEP))
            .filter(([gk, dk]) => guestKeys.has(gk) && drinkNames.has(dk))
            .map(([gk, dk]) => ({ guest: guestNames.get(gk)!, drink: drinkNames.get(dk)! })),
        };
        const res = await fetch(
          editingId ? `/api/admin/service-log/${editingId}` : "/api/admin/service-log",
          {
            method: editingId ? "PATCH" : "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          },
        );
        if (res.ok) {
          location.reload();
        } else {
          const j = (await res.json().catch(() => null)) as { error?: string } | null;
          showError(j?.error ?? "Didn’t take. Try again.");
        }
      });

      deleteBtn.addEventListener("click", async () => {
        if (!editingId || !confirm("Strike this night from the record?")) return;
        const res = await fetch(`/api/admin/service-log/${editingId}`, { method: "DELETE" });
        if (res.ok) location.reload();
        else showError("Didn’t take. Try again.");
      });
    }
  </script>

  <script>
    // Event cost tool (#80): admin-only island. Each save persists, then reloads — the page
    // re-SSRs every cost figure server-side (no client cost engine). Absent for signed-out
    // visitors, so this no-ops.
    const costSection = document.getElementById("event-cost");
    if (costSection) initEventCost(costSection);

    function initEventCost(section: HTMLElement) {
      const slug = section.dataset.slug ?? "";
      const byId = (id: string) => document.getElementById(id);

      const showError = (boxId: string, msgId: string, msg: string) => {
        const m = byId(msgId);
        if (m) m.textContent = msg;
        byId(boxId)?.classList.remove("is-hidden");
      };
      const clearError = (boxId: string) => byId(boxId)?.classList.add("is-hidden");

      async function post(path: string, payload: unknown): Promise<string | null> {
        const res = await fetch(path, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (res.ok) return null;
        const j = (await res.json().catch(() => null)) as { error?: string } | null;
        return j?.error ?? "Didn’t take. Try again.";
      }

      // ── Reconcile: collect every select, persist the resolved ones (unmatched are omitted) ──
      byId("rec-save")?.addEventListener("click", async () => {
        clearError("rec-error");
        const resolutions: { service_drink_id: number; recipe_id: number | null; dismissed: boolean }[] = [];
        section.querySelectorAll<HTMLElement>(".rec-row").forEach((row) => {
          const sel = row.querySelector(".rec-select") as HTMLSelectElement | null;
          if (!sel) return;
          const id = Number(row.dataset.drinkId);
          const v = sel.value;
          if (v === "") return;
          if (v === "dismiss") resolutions.push({ service_drink_id: id, recipe_id: null, dismissed: true });
          else resolutions.push({ service_drink_id: id, recipe_id: Number(v), dismissed: false });
        });
        const err = await post("/api/admin/event-cost/matches", { event_slug: slug, resolutions });
        if (err) showError("rec-error", "rec-error-msg", err);
        else location.reload();
      });

      // ── Incidentals: add / remove rows (client-built rows are :global in the stylesheet) ──
      const incList = byId("inc-list");
      const makeIncRow = () => {
        const row = document.createElement("div");
        row.className = "inc-row";
        row.innerHTML =
          '<input type="text" class="inc-label" maxlength="60" placeholder="what" aria-label="Incidental label" />' +
          '<span class="ec-affix">$</span>' +
          '<input type="number" min="0" step="0.01" class="inc-amount" placeholder="0.00" aria-label="Incidental amount" />' +
          '<button type="button" class="button ghost sm inc-remove" aria-label="Remove incidental">✕</button>';
        return row;
      };
      byId("inc-add")?.addEventListener("click", () => incList?.appendChild(makeIncRow()));
      incList?.addEventListener("click", (e) => {
        const t = e.target as HTMLElement;
        if (t.classList.contains("inc-remove")) t.closest(".inc-row")?.remove();
      });

      // ── Pricing: pseudo-juice toggle + overrides + incidentals, saved together ──
      byId("price-save")?.addEventListener("click", async () => {
        clearError("price-error");
        const use_pseudo_juice = (byId("pj-toggle") as HTMLInputElement | null)?.checked === true;
        let bad: string | null = null;

        const overrides: { ingredient_id: number; purchase_price: number; purchase_amount: number; purchase_unit: string }[] = [];
        section.querySelectorAll<HTMLElement>(".ec-agg tbody tr[data-ingredient-id]").forEach((row) => {
          const price = ((row.querySelector(".ov-price") as HTMLInputElement | null)?.value ?? "").trim();
          const amount = ((row.querySelector(".ov-amount") as HTMLInputElement | null)?.value ?? "").trim();
          const unit = ((row.querySelector(".ov-unit") as HTMLInputElement | null)?.value ?? "").trim();
          if (!price && !amount && !unit) return;
          if (!price || !amount || !unit) {
            bad = "An override needs a price, an amount, and a unit — or leave all three blank.";
            return;
          }
          overrides.push({
            ingredient_id: Number(row.dataset.ingredientId),
            purchase_price: Number(price),
            purchase_amount: Number(amount),
            purchase_unit: unit,
          });
        });
        if (bad) return showError("price-error", "price-error-msg", bad);

        const incidentals: { label: string; amount: number }[] = [];
        section.querySelectorAll<HTMLElement>(".inc-row").forEach((row) => {
          const label = ((row.querySelector(".inc-label") as HTMLInputElement | null)?.value ?? "").trim();
          const amount = ((row.querySelector(".inc-amount") as HTMLInputElement | null)?.value ?? "").trim();
          if (!label && !amount) return;
          if (!label || !amount) {
            bad = "An incidental needs a label and an amount.";
            return;
          }
          incidentals.push({ label, amount: Number(amount) });
        });
        if (bad) return showError("price-error", "price-error-msg", bad);

        const err = await post("/api/admin/event-cost/pricing", { event_slug: slug, use_pseudo_juice, overrides, incidentals });
        if (err) showError("price-error", "price-error-msg", err);
        else location.reload();
      });

      // ── Publish: flip the public total on/off (server snapshots it on enable) ──
      const pub = byId("pub-toggle") as HTMLInputElement | null;
      if (pub) {
        pub.addEventListener("change", async () => {
          byId("pub-error")?.classList.add("is-hidden");
          const enabled = pub.checked;
          const err = await post("/api/admin/event-cost/publish", { event_slug: slug, enabled });
          if (err) {
            pub.checked = !enabled;
            const pe = byId("pub-error");
            if (pe) {
              pe.textContent = err;
              pe.classList.remove("is-hidden");
            }
          } else {
            location.reload();
          }
        });
      }
    }
  </script>
</Layout>
