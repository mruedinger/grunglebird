---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Tools — grunglebird"
  description="Bar tools — spirit finder and more."
  active="tools"
>
  <main class="container center">
    <h1 class="page-title">Tools</h1>

    <div class="soon">
      <span class="badge">Coming soon</span>
      <h2>Spirit finder</h2>
      <p>Search store inventories for the bottle you're hunting.</p>
    </div>
  </main>

  <style>
    .soon {
      margin-top: 2rem;
    }
    .soon h2 {
      font-size: 1.85rem;
      margin: 0.9rem 0 0.4rem;
    }
    .soon p {
      color: var(--muted);
      max-width: 40ch;
      margin: 0 auto;
      line-height: 1.55;
    }
  </style>
</Layout>
