---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Tools — grunglebird"
  description="Bar tools — spirit finder and more."
  active="tools"
>
  <main class="container">
    <h1 class="hero">Tools</h1>
    <p class="copy muted">We have to find them first…</p>

    <div class="section-head">
      <h2>Spirit finder</h2>
      <span class="badge">Coming soon</span>
    </div>
  </main>

  <style>
    .section-head {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      margin-top: var(--space-xl);
    }
    .section-head h2 {
      margin: 0;
    }
  </style>
</Layout>
