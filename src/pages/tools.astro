---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Tools — grunglebird"
  description="Bar tools — spirit finder and more."
  active="tools"
>
  <main class="container">
    <h1 class="hero">Tools</h1>

    <div class="soon">
      <span class="badge">Coming soon</span>
      <h2>Spirit finder</h2>
      <p>Search store inventories for the bottle you're hunting.</p>
    </div>
  </main>

  <style>
    .soon {
      margin-top: var(--space-xl);
    }
    .soon h2 {
      font-size: var(--text-xl);
      margin: var(--space-sm) 0 var(--space-2xs);
    }
    .soon p {
      color: var(--muted);
      max-width: 40ch; /* copy measure — line length has no scale step */
      margin: 0;
      line-height: 1.55;
    }
  </style>
</Layout>
