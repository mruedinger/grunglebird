---
import Layout from "../layouts/Layout.astro";
import PromoPill from "../components/PromoPill.astro";
---

<Layout title="grunglebird" description="Mike's corner of the web for cocktail craft.">
  <main class="container home">
    <PromoPill href="/events/framily-beach-bar-2026" label="Mike's Beach Bar" />

    <section class="feature">
      <h2>Grungle Bird</h2>
      <p class="desc">
        Mike's riff on the Jungle Bird<br />funky, citrusy, bittersweet
      </p>
      <a class="feature-link" href="/cocktails">See the recipe →</a>
    </section>
  </main>

  <style>
    .home .feature {
      margin-top: var(--space-2xl);
    }
    .feature h2 {
      font-size: var(--text-xl);
      margin: 0 0 var(--space-xs);
    }
    .feature .desc {
      color: var(--muted);
      max-width: 42ch; /* copy measure — line length has no scale step */
      margin: 0;
      line-height: 1.6;
    }
    .feature-link {
      display: inline-block;
      margin-top: var(--space-md);
      color: var(--accent);
      font-weight: 500;
      font-size: var(--text-base);
    }
  </style>
</Layout>
