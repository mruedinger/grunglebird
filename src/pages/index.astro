---
import Layout from "../layouts/Layout.astro";
import PromoPill from "../components/PromoPill.astro";
---

<Layout title="grunglebird" description="Mike's corner of the web for cocktail craft.">
  <main class="container center home">
    <PromoPill href="/events/framily-beach-bar-2026" label="Mike's Beach Bar" />

    <section class="feature">
      <h2>Grungle Bird</h2>
      <p class="desc">
        Mike's riff on the Jungle Bird — a funky, citrusy, bittersweet harmony of
        grapefruit, Campari, and rum.
      </p>
      <a class="feature-link" href="/cocktails">See the recipe →</a>
    </section>
  </main>

  <style>
    .home .feature {
      margin-top: 3rem;
    }
    .feature h2 {
      font-size: 1.85rem;
      margin: 0 0 0.5rem;
    }
    .feature .desc {
      color: var(--muted);
      max-width: 42ch;
      margin: 0 auto;
      line-height: 1.6;
    }
    .feature-link {
      display: inline-block;
      margin-top: 1rem;
      color: var(--accent);
      font-weight: 500;
      font-size: 0.95rem;
    }
  </style>
</Layout>
